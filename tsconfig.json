{
  "compilerOptions": {
    /* 🔥 CORE */
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    /* 🔥 MODULE */
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    /* 🔥 REACT / NEXT */
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
    /* 🔥 STRICTNESS */
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    /* 🔥 PATH ALIAS (FIXED) */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./app/*"
      ]
    },
    /* 🔥 STABILITY */
    "forceConsistentCasingInFileNames": true,
    /* 🔥 PERFORMANCE */
    "incremental": true,
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}